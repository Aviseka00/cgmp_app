# Copy to .env and adjust. Pydantic reads these at startup (see app/config.py).

SECRET_KEY=replace-with-long-random-string
# Local: mongodb://localhost:27017
# Render / cloud: MongoDB Atlas (or other host) — never use localhost on PaaS; set in the host's Environment.
# MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=cgmp_cell_app

# Set true in production after creating real admin accounts (stops auto-creating "admin" / "admin123").
# DISABLE_SEED_ADMIN=true

# Local paths default under backend/. Put production_model.pth in weights/ or set explicitly:
# BEST_MODEL_PATH=D:/IPA/runs_cv_full/production_model.pth
# UPLOADS_DIR=
# PROCESSED_DIR=
# REPORTS_DIR=
# REGISTRY_DIR=
# CELL_DETECTION_DIR=

# Docker / process scaling (model memory may require UVICORN_WORKERS=1)
# UVICORN_WORKERS=1
